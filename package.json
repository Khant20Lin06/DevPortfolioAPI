{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "build": "node -e \"console.log('Backend build step not required')\"",
    "lint": "node -e \"console.log('Backend lint not configured yet')\"",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "worker:run": "node scripts/run-worker-once.js",
    "cleanup:retention": "node scripts/cleanup-expired.js",
    "seed:admin": "node scripts/seed-admin.js",
    "content:reset": "node scripts/reset-content-defaults.js"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0",
    "@sentry/node": "^8.52.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.6.0",
    "resend": "^4.1.2",
    "socket.io": "^4.8.1",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "prisma": "^6.4.0",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8"
  }
}
